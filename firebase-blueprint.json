{
  "entities": {
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global configuration for the website",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string", "description": "URL of the website logo" },
        "footerLogoUrl": { "type": "string", "description": "URL of the footer logo" },
        "heroImages": { "type": "array", "items": { "type": "string" }, "description": "URLs for the homepage hero image slider" },
        "companyName": { "type": "string", "description": "Name of the company" },
        "tagline": { "type": "string", "description": "Website tagline" },
        "contactEmail": { "type": "string", "description": "General contact email" },
        "phoneNumbers": { "type": "array", "items": { "type": "string" }, "description": "Contact phone numbers" },
        "aboutText": { "type": "string", "description": "Main about us text" },
        "vision": { "type": "string" },
        "visionImageUrl": { "type": "string", "description": "Image for the vision section on home" },
        "promoBannerTitle": { "type": "string", "description": "Promo banner heading" },
        "promoBannerText": { "type": "string", "description": "Promo banner subtext" },
        "mission": { "type": "string" },
        "commitment": { "type": "string" },
        "careersHeroImageUrl": { "type": "string" },
        "clientsHeroImageUrl": { "type": "string" }
      },
      "required": ["companyName", "logoUrl"]
    },
    "Category": {
      "title": "Book Category",
      "description": "Categories for grouping books",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "description": "Category icon/image URL" }
      },
      "required": ["name", "slug"]
    },
    "WhyRichkissItem": {
      "title": "Why Richkiss Item",
      "description": "Benefits/Features listed on careers page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["title", "imageUrl"]
    },
    "Book": {
      "title": "Book",
      "description": "A book in the catalogue",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "price": { "type": "string" },
        "coverUrl": { "type": "string" },
        "categorySlug": { "type": "string" },
        "featured": { "type": "boolean" },
        "year": { "type": "string" },
        "isbn": { "type": "string" },
        "dimensions": { "type": "string" },
        "bindingPages": { "type": "string" },
        "description": { "type": "string", "description": "Book blurb/synopsis" }
      },
      "required": ["title", "author", "coverUrl", "categorySlug"]
    },
    "Event": {
      "title": "Event",
      "description": "Company event or book fair",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "year": { "type": "string" },
        "description": { "type": "string" },
        "gallery": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "location"]
    },
    "PrintWork": {
      "title": "Print Work",
      "description": "Portfolio items for the print department",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["title", "imageUrl"]
    },
    "Partner": {
      "title": "Partner Logo",
      "description": "Partner/Client logos displayed on the site",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["name", "logoUrl"]
    }
  },
  "firestore": {
    "settings/global": {
      "schema": "SiteSettings",
      "description": "Global site settings"
    },
    "categories": {
      "schema": "Category",
      "description": "Collection of book categories"
    },
    "books": {
      "schema": "Book",
      "description": "Collection of books"
    },
    "events": {
      "schema": "Event",
      "description": "Collection of events"
    },
    "whyRichkiss": {
      "schema": "WhyRichkissItem",
      "description": "Benefits/Value props for careers page"
    },
    "printWorks": {
      "schema": "PrintWork",
      "description": "Portfolio items for the print department section"
    },
    "partners": {
      "schema": "Partner",
      "description": "Collection of partner logos"
    }
  }
}
