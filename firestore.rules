rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return true; // Simplified for the password-only UI request. In production, use Firebase Auth with custom claims.
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidSiteSettings(data) {
      return (data.get('companyName', '') is string) && data.get('companyName', '').size() <= 100 &&
             (data.get('logoUrl', '') is string) && data.get('logoUrl', '').size() <= 1000 &&
             (data.get('footerLogoUrl', '') is string) &&
             (data.get('heroImages', []) is list) &&
             (data.get('tagline', '') is string) &&
             (data.get('aboutText', '') is string) &&
             (data.get('vision', '') is string) &&
             (data.get('visionImageUrl', '') is string) &&
             (data.get('promoBannerTitle', '') is string) &&
             (data.get('promoBannerText', '') is string) &&
             (data.get('careersHeroImageUrl', '') is string) &&
             (data.get('clientsHeroImageUrl', '') is string) &&
             (data.get('mission', '') is string) &&
             (data.get('commitment', '') is string) &&
             (data.get('updatedAt', request.time) is timestamp);
    }

    function isValidCategory(data) {
      return (data.get('name', '') is string) && data.get('name', '').size() <= 100 &&
             (data.get('slug', '') is string) && data.get('slug', '').size() <= 100 &&
             (data.get('description', '') is string) &&
             (data.get('imageUrl', '') is string) &&
             (data.get('createdAt', request.time) is timestamp || data.get('updatedAt', request.time) is timestamp);
    }

    function isValidWhyRichkiss(data) {
      return (data.get('title', '') is string) && data.get('title', '').size() <= 200 &&
             (data.get('description', '') is string) &&
             (data.get('imageUrl', '') is string) &&
             (data.get('order', 0) is int);
    }

    function isValidBook(data) {
      return (data.get('title', '') is string) && data.get('title', '').size() <= 200 &&
             (data.get('author', '') is string) && data.get('author', '').size() <= 100 &&
             (data.get('coverUrl', '') is string) && data.get('coverUrl', '').size() <= 1000 &&
             (data.get('categorySlug', '') is string) && data.get('categorySlug', '').size() <= 100 &&
             (data.get('price', '') is string) &&
             (data.get('featured', false) is bool) &&
             (data.get('createdAt', request.time) is timestamp || data.get('updatedAt', request.time) is timestamp);
    }

    function isValidEvent(data) {
      return (data.get('name', '') is string) && data.get('name', '').size() <= 200 &&
             (data.get('location', '') is string) && data.get('location', '').size() <= 200 &&
             (data.get('year', '') is string) &&
             (data.get('description', '') is string) &&
             (data.get('gallery', []) is list) &&
             (data.get('createdAt', request.time) is timestamp || data.get('updatedAt', request.time) is timestamp);
    }

    function isValidPrintWork(data) {
      return (data.get('title', '') is string) && data.get('title', '').size() <= 200 &&
             (data.get('imageUrl', '') is string) && data.get('imageUrl', '').size() <= 1000 &&
             (data.get('category', '') is string) &&
             (data.get('order', 0) is int);
    }

    function isValidPartner(data) {
      return (data.get('name', '') is string) && data.get('name', '').size() <= 200 &&
             (data.get('logoUrl', '') is string) && data.get('logoUrl', '').size() <= 1000 &&
             (data.get('order', 0) is int);
    }

    // Match Blocks
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSiteSettings(incoming());
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(bookId) && isValidBook(incoming());
      allow update: if isAdmin() && isValidBook(incoming());
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(eventId) && isValidEvent(incoming());
      allow update: if isAdmin() && isValidEvent(incoming());
      allow delete: if isAdmin();
    }

    match /whyRichkiss/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(itemId) && isValidWhyRichkiss(incoming());
      allow update: if isAdmin() && isValidWhyRichkiss(incoming());
      allow delete: if isAdmin();
    }

    match /printWorks/{workId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(workId) && isValidPrintWork(incoming());
      allow update: if isAdmin() && isValidPrintWork(incoming());
      allow delete: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(partnerId) && isValidPartner(incoming());
      allow update: if isAdmin() && isValidPartner(incoming());
      allow delete: if isAdmin();
    }
  }
}
